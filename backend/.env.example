# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── MongoDB (required in production) ─────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Database name (default: infra_canvas)
MONGODB_DB=infra_canvas

# ── CORS ─────────────────────────────────────────────────────────────────────
# In production (single container) frontend is same-origin — leave as *
# or set to your Koyeb app domain e.g. https://your-app.koyeb.app
WEB_ORIGIN=*
