# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
#
# The backend selects the database automatically based on MONGODB_URI:
#
#   MONGODB_URI not set  →  SQLite (bun:sqlite)   ← LOCAL DEV — zero config
#   MONGODB_URI set      →  MongoDB (Mongoose)     ← PRODUCTION
#
# ── Option A: SQLite — local development (default) ───────────────────────────
# Leave MONGODB_URI commented out.
# SQLite DB file is auto-created at backend/data/app.db on first run.
# Tables are created automatically — no migrations CLI needed.
#
# Optional: change the SQLite file location:
# SQLITE_PATH=./data/app.db

# ── Option B: MongoDB — production ───────────────────────────────────────────
# Uncomment and set your MongoDB Atlas connection string to enable MongoDB:
#
# MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=infra_canvas

# ── CORS ─────────────────────────────────────────────────────────────────────
# In production (single container) frontend is same-origin — leave as *
# or restrict to your domain e.g. https://your-app.koyeb.app
# WEB_ORIGIN=*
